# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Neon Database ─────────────────────────────────────────────
# Found in: Neon Console → Project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Firebase Admin (Backend) ──────────────────────────────────
# Found in: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the private key exactly as it appears in the JSON file (including -----BEGIN/END-----)
# On Render: store as a multi-line secret env var
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8080
# Comma-separated extra origins allowed to call the API (e.g. alt/preview frontend deployments)
EXTRA_ALLOWED_ORIGINS=

# ── Firebase Client (Frontend) — prefix with VITE_ ───────────
# Found in: Firebase Console → Project Settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ── AfterShip ─────────────────────────────────────────────────
# Found in: AfterShip Dashboard → Developers → API Keys
AFTERSHIP_API_KEY=asat_xxxx
# Found in: AfterShip Dashboard → Settings → Notifications → Webhook → edit → Secret
# Leave empty to skip signature verification (fine for testing, required for production)
AFTERSHIP_WEBHOOK_SECRET=

# ── Admin ─────────────────────────────────────────────────────
# Comma-separated Firebase UIDs with admin access.
# Found in: Firebase Console → Authentication → Users → User UID column
ADMIN_UIDS=uid1,uid2

# ── Vite API proxy (leave empty in dev, set for production) ───
# VITE_API_URL=https://your-backend.onrender.com
